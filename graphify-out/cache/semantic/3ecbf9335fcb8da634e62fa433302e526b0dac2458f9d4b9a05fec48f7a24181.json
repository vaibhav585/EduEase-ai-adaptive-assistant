{"nodes": [{"id": "ai_assistant_neurodivergent_project_technical_audit_executive_summary", "label": "Technical Audit Executive Summary", "file_type": "document", "source_file": "project_technical_audit.html", "source_location": "section#summary", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_assistant_neurodivergent_project_technical_audit_global_chat_memory_bug", "label": "Global Chat Memory Sharing Bug", "file_type": "concept", "source_file": "project_technical_audit.html", "source_location": "section#bugs", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_assistant_neurodivergent_project_technical_audit_api_key_exposure", "label": "Hardcoded API Key Security Vulnerability", "file_type": "concept", "source_file": "project_technical_audit.html", "source_location": "section#security", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_assistant_neurodivergent_project_technical_audit_zero_auth", "label": "Zero Backend Authentication Finding", "file_type": "concept", "source_file": "project_technical_audit.html", "source_location": "section#security", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_assistant_neurodivergent_project_technical_audit_coppa_compliance", "label": "COPPA Compliance Gap", "file_type": "rationale", "source_file": "project_technical_audit.html", "source_location": "section#security", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Product processes data from children under 13 but lacks verifiable parental consent flow and data-minimization/retention policy. Must be closed before any pilot with real children's data."}, {"id": "ai_assistant_neurodivergent_project_technical_audit_dead_code", "label": "Dead Code and Scaffold Inventory", "file_type": "concept", "source_file": "project_technical_audit.html", "source_location": "section#architecture", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_assistant_neurodivergent_project_technical_audit_dual_implementation", "label": "Dual Implementation Architecture Problem", "file_type": "rationale", "source_file": "project_technical_audit.html", "source_location": "section#architecture", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A clean layered design (routers/services/schemas) was scaffolded but commented out. The live app is a monolithic reimplementation in app.py that diverges from it. Frontend mirrors this with dead routes/ directory duplicating pages/. Decision: pick one layer and delete the other."}, {"id": "ai_assistant_neurodivergent_project_technical_audit_rag_roadmap", "label": "Advanced RAG Pipeline Roadmap", "file_type": "rationale", "source_file": "project_technical_audit.html", "source_location": "section#rag", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three-phase plan: (1) parent-child chunking for retrieval precision vs answer coherence tradeoff, (2) metadata filtering for per-child personalization, (3) cross-encoder re-ranking before generation. Moves from whole-document prompting to scalable retrieval."}, {"id": "ai_assistant_neurodivergent_project_technical_audit_guardrails", "label": "Safety and Guardrail Layer Design", "file_type": "rationale", "source_file": "project_technical_audit.html", "source_location": "section#guardrails", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Input rail checks topic restriction, jailbreak detection, PII detection before LLM. Output rail checks toxicity, age-appropriateness, fact-grounding against RAG context. Uses NeMo Guardrails + Llama Guard as defense-in-depth for child safety."}, {"id": "ai_assistant_neurodivergent_project_technical_audit_multimodal_adaptive", "label": "Multimodal and Adaptive Tech Roadmap", "file_type": "rationale", "source_file": "project_technical_audit.html", "source_location": "section#multimodal", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three components: (1) STT input via Web Speech API with Whisper fallback for dyslexic/pre-literate children, (2) real-time sentiment analysis using DistilBERT or Gemini structured output to detect frustration, (3) behavioral adaptation loop connecting eye-tracking focus signal to automatic content adjustments."}, {"id": "ai_assistant_neurodivergent_project_technical_audit_accessibility_ux", "label": "Accessibility and UX for Neurodivergent Children", "file_type": "rationale", "source_file": "project_technical_audit.html", "source_location": "section#a11y", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Unconditional animations during stress moments counter-productive for vestibular sensitivity. No prefers-reduced-motion support, no aria-live regions, no screen-reader state change support. Sensory customization features (DyslexiaMode, AutismMode, Settings) exist only as stub routes."}, {"id": "ai_assistant_neurodivergent_project_technical_audit_event_loop_blocking", "label": "Event Loop Blocking Performance Issue", "file_type": "concept", "source_file": "project_technical_audit.html", "source_location": "section#perf", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_assistant_neurodivergent_project_technical_audit_client_side_role_gate", "label": "Client-Side Only Role-Based Access Control", "file_type": "concept", "source_file": "project_technical_audit.html", "source_location": "section#security", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_assistant_neurodivergent_project_technical_audit_password_console_log", "label": "Plaintext Password Console Logging", "file_type": "concept", "source_file": "project_technical_audit.html", "source_locati